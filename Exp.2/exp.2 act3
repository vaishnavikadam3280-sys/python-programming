def calculate_bill(units):
    bill = 0
    
    if units <= 100:
        bill = 0
    elif units <= 200:
        bill = (units - 100) * 5
    else:
        bill = (100 * 5) + (units - 200) * 10
        
    return bill

units_consumed = float(input("Enter units consumed: "))
total_bill = calculate_bill(units_consumed)
print(f"Total Electricity Bill: ₹{total_bill}")
