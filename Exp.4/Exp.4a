n = int(input("Enter number of element: "))
numbers = []

for i in range(n):
  num = int(input(f"Enter element{i+1}:"))
  numbers.append(num)

  #calculating sum and average
  total = sum(numbers)
  average = total/n if n>0 else 0
  
  print("List:",numbers)
  print("sum of element:",total)
  print("Average of elements:",average)
